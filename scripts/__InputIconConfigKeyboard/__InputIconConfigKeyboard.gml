InputIconDefineKeyboard(vk_numpad0, new UISpriteIcon(sprt_UI_KBIcon_Numpad,0));//"Numpad 0");
InputIconDefineKeyboard(vk_numpad1, new UISpriteIcon(sprt_UI_KBIcon_Numpad,1));//"Numpad 1");
InputIconDefineKeyboard(vk_numpad2, new UISpriteIcon(sprt_UI_KBIcon_Numpad,2));//"Numpad 2");
InputIconDefineKeyboard(vk_numpad3, new UISpriteIcon(sprt_UI_KBIcon_Numpad,3));//"Numpad 3");
InputIconDefineKeyboard(vk_numpad4, new UISpriteIcon(sprt_UI_KBIcon_Numpad,4));//"Numpad 4");
InputIconDefineKeyboard(vk_numpad5, new UISpriteIcon(sprt_UI_KBIcon_Numpad,5));//"Numpad 5");
InputIconDefineKeyboard(vk_numpad6, new UISpriteIcon(sprt_UI_KBIcon_Numpad,6));//"Numpad 6");
InputIconDefineKeyboard(vk_numpad7, new UISpriteIcon(sprt_UI_KBIcon_Numpad,7));//"Numpad 7");
InputIconDefineKeyboard(vk_numpad8, new UISpriteIcon(sprt_UI_KBIcon_Numpad,8));//"Numpad 8");
